# Normalize line endings to LF on check-in
* text=auto eol=lf

# PHP / JS / CSS / templates → text
*.php       text eol=lf
*.js        text eol=lf
*.css       text eol=lf
*.tpl       text eol=lf
*.html      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.sql       text eol=lf
*.htaccess  text eol=lf
*.editorconfig text eol=lf

# Binary assets — no diff, no merge
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.svg       text eol=lf
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.zip       binary

# Export-ignore: files not included in GitHub ZIP / archive downloads
.gitattributes  export-ignore
.gitignore      export-ignore
.editorconfig   export-ignore
CHANGELOG.md    export-ignore
